# PostgreSQL (match docker-compose credentials, or your local instance)
DATABASE_URL="postgresql://gameplatform:gameplatform@localhost:5432/gameplatform"

# Auth.js — required in production; use a long random string (e.g. openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-secret-in-production"

# Optional: public URL of the app (useful behind proxies / non-localhost)
# AUTH_URL="http://localhost:3000"
